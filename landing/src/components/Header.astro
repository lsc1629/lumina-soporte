---
const navLinks = [
  { label: 'Funcionalidades', href: '#features' },
  { label: 'Cómo funciona', href: '#how-it-works' },
  { label: 'Planes', href: '#pricing' },
  { label: 'FAQ', href: '#faq' },
];

const appUrl = 'https://soporte.luissalascortes.dev';
---

<header class="fixed top-0 left-0 right-0 z-50 transition-all" id="main-header">
  <div class="section-padding">
    <nav class="flex items-center justify-between py-4">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 group">
        <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-primary shadow-lg shadow-primary/20 transition-transform group-hover:scale-105">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-white">
            <path d="M12 2L2 7l10 5 10-5-10-5z" />
            <path d="M2 17l10 5 10-5" />
            <path d="M2 12l10 5 10-5" />
          </svg>
        </div>
        <span class="font-display text-lg font-bold text-white">Lumina<span class="text-primary-light">Support</span></span>
      </a>

      <!-- Desktop nav -->
      <div class="hidden md:flex items-center gap-8">
        {navLinks.map(link => (
          <a href={link.href} class="text-sm text-gray-400 hover:text-white transition-colors font-medium">{link.label}</a>
        ))}
      </div>

      <!-- CTA -->
      <div class="hidden md:flex items-center gap-3">
        <a href={appUrl} class="text-sm font-medium text-gray-300 hover:text-white transition-colors px-4 py-2">
          Iniciar sesión
        </a>
        <a href={`${appUrl}?signup=true`} class="btn-primary !py-2 !px-5 !text-xs">
          Comenzar gratis
        </a>
      </div>

      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="md:hidden flex items-center justify-center h-10 w-10 rounded-xl border border-white/10 text-gray-400 hover:text-white transition-colors" aria-label="Menú">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 6h16M4 12h16M4 18h16" /></svg>
      </button>
    </nav>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-white/5 bg-surface/95 backdrop-blur-xl">
    <div class="section-padding py-4 space-y-3">
      {navLinks.map(link => (
        <a href={link.href} class="block text-sm text-gray-400 hover:text-white transition-colors py-2">{link.label}</a>
      ))}
      <div class="pt-3 border-t border-white/5 space-y-2">
        <a href={appUrl} class="block text-sm text-gray-300 hover:text-white py-2">Iniciar sesión</a>
        <a href={`${appUrl}?signup=true`} class="btn-primary w-full !text-xs justify-center">Comenzar gratis</a>
      </div>
    </div>
  </div>
</header>

<script>
  // Header scroll effect
  const header = document.getElementById('main-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      header?.classList.add('bg-surface/80', 'backdrop-blur-xl', 'border-b', 'border-white/5');
    } else {
      header?.classList.remove('bg-surface/80', 'backdrop-blur-xl', 'border-b', 'border-white/5');
    }
  });

  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => menu?.classList.add('hidden')));
</script>
