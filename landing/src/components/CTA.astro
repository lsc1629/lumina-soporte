---
const appUrl = 'https://soporte.luissalascortes.dev';
---

<section class="py-24 lg:py-32 relative">
  <div class="section-padding">
    <div class="relative rounded-3xl overflow-hidden">
      <!-- Background -->
      <div class="absolute inset-0 bg-gradient-to-br from-primary/20 via-surface-card to-secondary/10"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(108,99,255,0.15),transparent_60%)]"></div>
      <div class="absolute top-0 right-0 w-[300px] h-[300px] bg-primary/10 rounded-full blur-[80px]"></div>
      <div class="absolute bottom-0 left-0 w-[200px] h-[200px] bg-secondary/10 rounded-full blur-[60px]"></div>

      <!-- Content -->
      <div class="relative px-8 py-16 sm:px-16 sm:py-20 text-center">
        <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4 leading-tight">
          Protege tus sitios web
          <br />
          <span class="gradient-text">desde hoy</span>
        </h2>
        <p class="text-gray-400 max-w-xl mx-auto mb-10 text-lg">
          Comienza gratis. Sin tarjeta de crédito. Configura tu primer sitio en menos de 2 minutos.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href={`${appUrl}?signup=true`} class="btn-primary text-base !px-10 !py-4 shadow-xl shadow-primary/25">
            Crear cuenta gratis
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="#pricing" class="btn-secondary text-base !px-10 !py-4">
            Ver planes
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
