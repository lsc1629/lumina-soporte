---
const features = [
  {
    icon: `<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>`,
    title: 'Monitoreo 24/7',
    description: 'Tu sitio se revisa cada 3-5 minutos. Si algo falla, lo sabrás en menos de 3 minutos.',
    color: 'text-primary-light',
    bg: 'bg-primary/10',
  },
  {
    icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/>`,
    title: 'Certificado SSL',
    description: 'Monitoreo automático de tu certificado de seguridad. Aviso anticipado antes del vencimiento.',
    color: 'text-secondary',
    bg: 'bg-secondary/10',
  },
  {
    icon: `<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>`,
    title: 'Actualizaciones remotas',
    description: 'Actualiza plugins, temas y WordPress desde el panel. Sin entrar al admin de cada sitio.',
    color: 'text-yellow-400',
    bg: 'bg-yellow-500/10',
  },
  {
    icon: `<path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>`,
    title: 'Alertas inteligentes',
    description: 'Notificaciones por email cuando algo falla. Doble verificación para evitar falsas alarmas.',
    color: 'text-red-400',
    bg: 'bg-red-500/10',
  },
  {
    icon: `<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/>`,
    title: 'Panel para clientes',
    description: 'Cada cliente accede a su propio panel con uptime, incidentes y tickets de soporte.',
    color: 'text-cyan-400',
    bg: 'bg-cyan-500/10',
  },
  {
    icon: `<path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/>`,
    title: 'Conexión con un clic',
    description: 'Instala el plugin Lumina Agent, pega tu API Key y listo. Sin configuración compleja.',
    color: 'text-violet-400',
    bg: 'bg-violet-500/10',
  },
];
---

<section id="features" class="py-24 lg:py-32 relative">
  <div class="section-padding">
    <!-- Section header -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="text-xs font-semibold uppercase tracking-widest text-primary mb-3 block">Funcionalidades</span>
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4">
        Todo lo que necesitas para <span class="gradient-text">proteger tus sitios</span>
      </h2>
      <p class="text-gray-400">
        Monitoreo proactivo, actualizaciones remotas y alertas inteligentes en una sola plataforma.
      </p>
    </div>

    <!-- Features grid -->
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((f, i) => (
        <div
          class="glass-card p-6 group hover:border-primary/20 transition-all duration-300 hover:-translate-y-1"
          style={`animation: slideUp 0.5s ease-out ${i * 0.08}s both`}
        >
          <div class={`flex h-12 w-12 items-center justify-center rounded-xl ${f.bg} mb-4 transition-transform group-hover:scale-110`}>
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={f.color}>
              <Fragment set:html={f.icon} />
            </svg>
          </div>
          <h3 class="font-display text-lg font-semibold text-white mb-2">{f.title}</h3>
          <p class="text-sm text-gray-400 leading-relaxed">{f.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
