---
const plans = [
  {
    slug: 'web',
    name: 'Sitio Web',
    price: '$14.990',
    period: '/mes',
    currency: 'CLP',
    description: 'Monitoreo completo para tu sitio web WordPress. Detecta problemas antes de que tus visitas lo noten.',
    features: [
      '1 sitio web WordPress',
      'Monitoreo cada 5 minutos, 24/7',
      'Alertas por email instantáneas',
      'Certificado SSL monitoreado',
      'Actualizaciones remotas de plugins y temas',
      'Detección de caídas con doble verificación',
      'Página de estado pública',
      'Reporte mensual automático',
      'Panel de cliente con historial de uptime',
      'Conexión con un clic vía Lumina Agent',
    ],
    cta: 'Contratar plan Web',
    highlighted: false,
    icon: `<path d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/><path d="M3.6 9h16.8"/><path d="M3.6 15h16.8"/><path d="M12 3a15.3 15.3 0 0 1 0 18"/><path d="M12 3a15.3 15.3 0 0 0 0 18"/>`,
  },
  {
    slug: 'ecommerce',
    name: 'Ecommerce',
    price: '$29.990',
    period: '/mes',
    currency: 'CLP',
    description: 'Todo lo del plan Web más monitoreo especializado para WooCommerce y Shopify.',
    features: [
      '1 tienda online (WooCommerce o Shopify)',
      'Monitoreo cada 3 minutos, 24/7',
      'Alertas por email instantáneas',
      'Certificado SSL monitoreado',
      'Actualizaciones remotas de plugins y temas',
      'Detección de caídas con doble verificación',
      'Monitoreo de estado WooCommerce / Shopify',
      'Escaneo de imágenes no optimizadas',
      'Página de estado pública personalizada',
      'Reporte mensual detallado con PDF',
      'Panel de cliente con historial completo',
      'Soporte prioritario',
    ],
    cta: 'Contratar plan Ecommerce',
    highlighted: true,
    icon: `<circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>`,
  },
];
---

<section id="pricing" class="py-24 lg:py-32 relative">
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/2 right-0 w-[600px] h-[600px] bg-primary/5 rounded-full blur-[120px] -translate-y-1/2"></div>
  </div>

  <div class="section-padding relative z-10">
    <!-- Section header -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="text-xs font-semibold uppercase tracking-widest text-primary mb-3 block">Planes</span>
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4">
        Elige el plan <span class="gradient-text">perfecto para ti</span>
      </h2>
      <p class="text-gray-400">
        Sin sorpresas. Sin contratos. Cancela cuando quieras.
      </p>
    </div>

    <!-- Plans grid -->
    <div class="grid gap-8 lg:grid-cols-2 max-w-4xl mx-auto">
      {plans.map((plan, i) => (
        <div
          class:list={[
            'relative rounded-2xl p-8 transition-all duration-300 hover:-translate-y-1',
            plan.highlighted
              ? 'bg-gradient-to-b from-primary/10 to-surface-card border-2 border-primary/30 shadow-2xl shadow-primary/10'
              : 'glass-card',
          ]}
          style={`animation: slideUp 0.5s ease-out ${i * 0.1}s both`}
        >
          {plan.highlighted && (
            <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
              <span class="inline-flex items-center gap-1 rounded-full bg-primary px-4 py-1 text-xs font-bold text-white shadow-lg">
                Recomendado
              </span>
            </div>
          )}

          <div class="mb-6">
            <!-- Plan icon + name -->
            <div class="flex items-center gap-3 mb-3">
              <div class={`flex h-11 w-11 items-center justify-center rounded-xl ${plan.highlighted ? 'bg-primary/15' : 'bg-secondary/10'}`}>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={plan.highlighted ? 'text-primary-light' : 'text-secondary'}>
                  <Fragment set:html={plan.icon} />
                </svg>
              </div>
              <h3 class="font-display text-xl font-bold text-white">{plan.name}</h3>
            </div>
            <p class="text-sm text-gray-400 mb-5">{plan.description}</p>
            <div class="flex items-baseline gap-1.5">
              <span class="font-display text-4xl font-bold text-white">{plan.price}</span>
              <span class="text-gray-500">{plan.period}</span>
            </div>
            <p class="text-xs text-gray-600 mt-1">Precio en pesos chilenos (CLP), IVA incluido</p>
          </div>

          <ul class="space-y-3 mb-8">
            {plan.features.map(f => (
              <li class="flex items-start gap-3 text-sm text-gray-300">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class={`mt-0.5 shrink-0 ${plan.highlighted ? 'text-primary' : 'text-secondary/70'}`}>
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                {f}
              </li>
            ))}
          </ul>

          <a
            href={`/signup?plan=${plan.slug}`}
            class:list={[
              'block w-full text-center rounded-xl px-6 py-3.5 text-sm font-semibold transition-all',
              plan.highlighted
                ? 'bg-primary text-white hover:bg-primary-dark shadow-lg shadow-primary/25 hover:shadow-primary/40'
                : 'border border-white/10 bg-white/5 text-white hover:bg-white/10',
            ]}
          >
            {plan.cta}
          </a>
        </div>
      ))}
    </div>

    <!-- Guarantee -->
    <div class="text-center mt-12">
      <p class="text-sm text-gray-500">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-block mr-1 text-secondary/60 -mt-0.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
        Sin contratos. Cancela cuando quieras. Prueba 7 días gratis.
      </p>
    </div>
  </div>
</section>
