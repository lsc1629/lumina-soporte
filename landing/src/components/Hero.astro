---
const appUrl = 'https://soporte.luissalascortes.dev';
---

<section class="relative pt-32 pb-20 lg:pt-44 lg:pb-32 overflow-hidden">
  <!-- Background effects -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-primary/10 rounded-full blur-[120px]"></div>
    <div class="absolute top-1/3 left-1/4 w-[400px] h-[400px] bg-secondary/8 rounded-full blur-[100px]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_20%,var(--tw-gradient-from))] from-surface"></div>
  </div>

  <div class="section-padding relative z-10">
    <div class="max-w-4xl mx-auto text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/5 px-4 py-1.5 mb-8 animate-fade-in">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-secondary opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-secondary"></span>
        </span>
        <span class="text-xs font-medium text-gray-300">Monitoreo activo 24/7 para tus sitios</span>
      </div>

      <!-- Heading -->
      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold leading-[1.1] tracking-tight mb-6 animate-slide-up">
        Tus sitios web,
        <br />
        <span class="gradient-text">siempre protegidos</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-lg sm:text-xl text-gray-400 max-w-2xl mx-auto mb-10 animate-slide-up" style="animation-delay: 0.1s">
        Detecta caídas, certificados SSL vencidos y plugins desactualizados antes de que tus clientes lo noten. 
        <strong class="text-gray-200">Todo en piloto automático.</strong>
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16 animate-slide-up" style="animation-delay: 0.2s">
        <a href={`${appUrl}?signup=true`} class="btn-primary text-base !px-8 !py-3.5 shadow-xl shadow-primary/20">
          Comenzar gratis
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="#how-it-works" class="btn-secondary text-base !px-8 !py-3.5">
          Ver cómo funciona
        </a>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-3 gap-6 max-w-lg mx-auto animate-fade-in" style="animation-delay: 0.4s">
        <div class="text-center">
          <p class="font-display text-2xl sm:text-3xl font-bold text-white">99.9%</p>
          <p class="text-xs text-gray-500 mt-1">Precisión detección</p>
        </div>
        <div class="text-center">
          <p class="font-display text-2xl sm:text-3xl font-bold text-white">&lt;3 min</p>
          <p class="text-xs text-gray-500 mt-1">Tiempo de alerta</p>
        </div>
        <div class="text-center">
          <p class="font-display text-2xl sm:text-3xl font-bold text-white">24/7</p>
          <p class="text-xs text-gray-500 mt-1">Monitoreo continuo</p>
        </div>
      </div>
    </div>

    <!-- Dashboard preview mockup -->
    <div class="mt-20 max-w-5xl mx-auto animate-slide-up" style="animation-delay: 0.3s">
      <div class="glass-card p-2 shadow-2xl shadow-primary/5 animate-pulse-glow">
        <div class="rounded-xl bg-surface overflow-hidden border border-white/5">
          <!-- Mock browser bar -->
          <div class="flex items-center gap-2 px-4 py-3 border-b border-white/5 bg-surface-light/50">
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full bg-red-500/60"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500/60"></div>
              <div class="w-3 h-3 rounded-full bg-green-500/60"></div>
            </div>
            <div class="flex-1 flex justify-center">
              <div class="flex items-center gap-2 rounded-lg bg-white/5 px-4 py-1">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-green-400"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
                <span class="text-xs text-gray-500">soporte.luissalascortes.dev</span>
              </div>
            </div>
          </div>
          <!-- Mock dashboard content -->
          <div class="p-6 space-y-4">
            <div class="flex items-center justify-between">
              <div>
                <div class="h-3 w-32 rounded bg-white/10"></div>
                <div class="h-2 w-48 rounded bg-white/5 mt-2"></div>
              </div>
              <div class="flex gap-2">
                <div class="h-8 w-20 rounded-lg bg-primary/20"></div>
                <div class="h-8 w-20 rounded-lg bg-white/5"></div>
              </div>
            </div>
            <!-- Stats row -->
            <div class="grid grid-cols-4 gap-3">
              <div class="rounded-xl bg-white/5 p-4">
                <div class="h-2 w-12 rounded bg-primary/30 mb-3"></div>
                <div class="h-5 w-10 rounded bg-white/15"></div>
              </div>
              <div class="rounded-xl bg-white/5 p-4">
                <div class="h-2 w-16 rounded bg-secondary/30 mb-3"></div>
                <div class="h-5 w-14 rounded bg-white/15"></div>
              </div>
              <div class="rounded-xl bg-white/5 p-4">
                <div class="h-2 w-14 rounded bg-yellow-500/30 mb-3"></div>
                <div class="h-5 w-8 rounded bg-white/15"></div>
              </div>
              <div class="rounded-xl bg-white/5 p-4">
                <div class="h-2 w-10 rounded bg-green-500/30 mb-3"></div>
                <div class="h-5 w-16 rounded bg-white/15"></div>
              </div>
            </div>
            <!-- Chart mock -->
            <div class="rounded-xl bg-white/5 p-4 h-40 flex items-end gap-1">
              {[40,65,45,80,55,90,70,85,60,95,75,88,50,82,92,78,86,68,94,72].map(h => (
                <div class="flex-1 rounded-t bg-gradient-to-t from-primary/40 to-primary/10" style={`height: ${h}%`}></div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
