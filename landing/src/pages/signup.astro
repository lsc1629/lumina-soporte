---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const plans: Record<string, { name: string; price: string; slug: string }> = {
  web: { name: 'Sitio Web', price: '$14.990/mes', slug: 'web' },
  ecommerce: { name: 'Ecommerce', price: '$29.990/mes', slug: 'ecommerce' },
};
---

<Layout title="Crear cuenta — LuminaSupport">
  <Header />
  <main class="pt-32 pb-24 min-h-screen">
    <div class="section-padding">
      <div class="max-w-md mx-auto">
        <!-- Plan badge (se rellena con JS) -->
        <div id="plan-badge" class="text-center mb-8 hidden">
          <div class="inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/5 px-5 py-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
              <polyline points="20 6 9 17 4 12" />
            </svg>
            <span class="text-sm text-gray-300">Plan <strong id="plan-name" class="text-white"></strong> — <span id="plan-price" class="text-primary-light"></span></span>
          </div>
        </div>

        <!-- Title -->
        <div class="text-center mb-10">
          <h1 class="font-display text-3xl font-bold text-white mb-3">Crea tu cuenta</h1>
          <p class="text-gray-400 text-sm">Comienza tu prueba gratuita de 7 días. Sin tarjeta de crédito.</p>
        </div>

        <!-- Signup form -->
        <form id="signup-form" class="space-y-5">
          <input type="hidden" id="selected-plan" name="plan" value="" />

          <div>
            <label for="full_name" class="block text-sm font-medium text-gray-300 mb-1.5">Nombre completo</label>
            <input
              type="text"
              id="full_name"
              name="full_name"
              required
              placeholder="Juan Pérez"
              class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white placeholder:text-gray-600 focus:border-primary/50 focus:outline-none focus:ring-1 focus:ring-primary/30 transition-colors"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-gray-300 mb-1.5">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="juan@empresa.cl"
              class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white placeholder:text-gray-600 focus:border-primary/50 focus:outline-none focus:ring-1 focus:ring-primary/30 transition-colors"
            />
          </div>

          <div>
            <label for="company" class="block text-sm font-medium text-gray-300 mb-1.5">Empresa <span class="text-gray-600">(opcional)</span></label>
            <input
              type="text"
              id="company"
              name="company"
              placeholder="Mi Empresa SpA"
              class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white placeholder:text-gray-600 focus:border-primary/50 focus:outline-none focus:ring-1 focus:ring-primary/30 transition-colors"
            />
          </div>

          <div>
            <label for="password" class="block text-sm font-medium text-gray-300 mb-1.5">Contraseña</label>
            <input
              type="password"
              id="password"
              name="password"
              required
              minlength="8"
              placeholder="Mínimo 8 caracteres"
              class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white placeholder:text-gray-600 focus:border-primary/50 focus:outline-none focus:ring-1 focus:ring-primary/30 transition-colors"
            />
          </div>

          <!-- Error message -->
          <div id="error-msg" class="hidden rounded-xl border border-red-500/20 bg-red-500/5 px-4 py-3 text-sm text-red-400"></div>

          <!-- Submit -->
          <button
            type="submit"
            id="submit-btn"
            class="btn-primary w-full justify-center !py-3.5 text-base"
          >
            <span id="btn-text">Crear cuenta y comenzar</span>
            <svg id="btn-spinner" class="hidden animate-spin h-5 w-5" viewBox="0 0 24 24" fill="none">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
          </button>

          <p class="text-center text-xs text-gray-600 mt-4">
            ¿Ya tienes cuenta?
            <a href="https://soporte.luissalascortes.dev" class="text-primary hover:text-primary-light transition-colors">Inicia sesión</a>
          </p>
        </form>

        <!-- Plan selector (si no viene plan en URL) -->
        <div id="plan-selector" class="hidden mt-10">
          <p class="text-sm text-gray-400 text-center mb-4">Selecciona tu plan:</p>
          <div class="grid grid-cols-2 gap-3">
            <button data-plan="web" class="plan-option glass-card p-4 text-center hover:border-primary/30 transition-all group">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-2 text-secondary group-hover:text-secondary-light transition-colors">
                <path d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/><path d="M3.6 9h16.8"/><path d="M3.6 15h16.8"/><path d="M12 3a15.3 15.3 0 0 1 0 18"/><path d="M12 3a15.3 15.3 0 0 0 0 18"/>
              </svg>
              <p class="font-display text-sm font-bold text-white">Sitio Web</p>
              <p class="text-xs text-gray-500 mt-1">$14.990/mes</p>
            </button>
            <button data-plan="ecommerce" class="plan-option glass-card p-4 text-center hover:border-primary/30 transition-all group">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-2 text-primary group-hover:text-primary-light transition-colors">
                <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
              </svg>
              <p class="font-display text-sm font-bold text-white">Ecommerce</p>
              <p class="text-xs text-gray-500 mt-1">$29.990/mes</p>
            </button>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  const SUPABASE_URL = 'https://vwddlfdhuajgssjqeomm.supabase.co';
  const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZ3ZGRsZmRodWFqZ3NzanFlb21tIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Mzk1NjcxOTMsImV4cCI6MjA1NTE0MzE5M30.xH1VMAqx3WBPCao-kDih0ewMSBBbkN3s9zxR-WBkfvA';

  const plans: Record<string, { name: string; price: string }> = {
    web: { name: 'Sitio Web', price: '$14.990/mes' },
    ecommerce: { name: 'Ecommerce', price: '$29.990/mes' },
  };

  // Leer plan de URL
  const params = new URLSearchParams(window.location.search);
  let selectedPlan = params.get('plan') || '';

  const badge = document.getElementById('plan-badge')!;
  const planNameEl = document.getElementById('plan-name')!;
  const planPriceEl = document.getElementById('plan-price')!;
  const planInput = document.getElementById('selected-plan') as HTMLInputElement;
  const planSelector = document.getElementById('plan-selector')!;

  function setPlan(slug: string) {
    const plan = plans[slug];
    if (!plan) return;
    selectedPlan = slug;
    planInput.value = slug;
    planNameEl.textContent = plan.name;
    planPriceEl.textContent = plan.price;
    badge.classList.remove('hidden');
    planSelector.classList.add('hidden');

    // Highlight selected
    document.querySelectorAll('.plan-option').forEach(el => {
      el.classList.toggle('border-primary/40', (el as HTMLElement).dataset.plan === slug);
      el.classList.toggle('bg-primary/5', (el as HTMLElement).dataset.plan === slug);
    });
  }

  if (selectedPlan && plans[selectedPlan]) {
    setPlan(selectedPlan);
  } else {
    planSelector.classList.remove('hidden');
  }

  // Plan selector buttons
  document.querySelectorAll('.plan-option').forEach(btn => {
    btn.addEventListener('click', () => {
      const slug = (btn as HTMLElement).dataset.plan!;
      setPlan(slug);
      // Update URL
      const url = new URL(window.location.href);
      url.searchParams.set('plan', slug);
      history.replaceState(null, '', url.toString());
    });
  });

  // Form submit
  const form = document.getElementById('signup-form') as HTMLFormElement;
  const errorMsg = document.getElementById('error-msg')!;
  const submitBtn = document.getElementById('submit-btn')!;
  const btnText = document.getElementById('btn-text')!;
  const btnSpinner = document.getElementById('btn-spinner')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMsg.classList.add('hidden');

    if (!selectedPlan) {
      errorMsg.textContent = 'Selecciona un plan antes de continuar.';
      errorMsg.classList.remove('hidden');
      return;
    }

    const fullName = (document.getElementById('full_name') as HTMLInputElement).value.trim();
    const email = (document.getElementById('email') as HTMLInputElement).value.trim();
    const company = (document.getElementById('company') as HTMLInputElement).value.trim();
    const password = (document.getElementById('password') as HTMLInputElement).value;

    if (password.length < 8) {
      errorMsg.textContent = 'La contraseña debe tener al menos 8 caracteres.';
      errorMsg.classList.remove('hidden');
      return;
    }

    // UI loading
    submitBtn.setAttribute('disabled', 'true');
    btnText.textContent = 'Creando cuenta...';
    btnSpinner.classList.remove('hidden');

    try {
      const res = await fetch(`${SUPABASE_URL}/functions/v1/signup-and-subscribe`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'apikey': SUPABASE_ANON_KEY,
        },
        body: JSON.stringify({
          email,
          password,
          full_name: fullName,
          company_name: company,
          plan_slug: selectedPlan,
        }),
      });

      const result = await res.json();

      if (!res.ok || result.error) {
        throw new Error(result.error || `Error ${res.status}`);
      }

      // Si hay checkout_url (Mercado Pago), redirigir
      if (result.checkout_url) {
        window.location.href = result.checkout_url;
        return;
      }

      // Si no, redirigir al panel con mensaje de éxito
      window.location.href = `https://soporte.luissalascortes.dev?welcome=true&plan=${selectedPlan}`;

    } catch (err: any) {
      errorMsg.textContent = err.message || 'Error al crear la cuenta. Intenta de nuevo.';
      errorMsg.classList.remove('hidden');
      submitBtn.removeAttribute('disabled');
      btnText.textContent = 'Crear cuenta y comenzar';
      btnSpinner.classList.add('hidden');
    }
  });
</script>
